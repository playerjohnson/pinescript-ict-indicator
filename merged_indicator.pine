else if isFvgDown(0) and not isFvgDown(1) and (liquidityvoidmode or Inversefvgmode) and not plotFVG
	float _fTop = low[2]
	float _fBot = high[0]
	if fvgAnchorVI and _anyVI0()
		_fTop := math.max(_fTop, math.max(open[0], close[1]))
		_fBot := math.min(_fBot, math.min(open[0], close[1]))
	if fvgAnchorVI and _anyVI1()
		_fTop := math.max(_fTop, math.max(open[1], close[2]))
		_fBot := math.min(_fBot, math.min(open[1], close[2]))
	box _bearboxFVG = box.new(left = bar_index - 2, top = _fTop, right = bar_index, bottom = _fBot, bgcolor = fvgBearColor, border_color = color.new(fvgBearColor, BorderTransparency), border_width = 1, text = plotBoxLabel ? 'FVG-' : na, border_style = BoxBorder, text_halign = labelhalign, text_valign = labelvalign, text_size = BoxLabelSize, text_color = BoxLabelColor)
	line _beline = cefvg ? line.new(bar_index - 2, math.avg(_fTop, _fBot), bar_index, math.avg(_fTop, _fBot), style = celinetype, color = color.new(fvgBearColor, cetransparency)) : na
	if array.size(_bearBoxesFVG) > fvgMaxBoxSet and array.size(_befvgce) > fvgMaxBoxSet
