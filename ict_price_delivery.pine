if isBeIFvg(0) and showifvg and ENABLE_IMBALANCES
	float _ifTop = (math.min(open[2], close[2]) + low[2]) / 2
	float _ifBot = (math.max(open, close) + high) / 2
	box _bearboxifvg = box.new(left = bar_index - 2, top = _ifTop, right = bar_index + 1, bottom = _ifBot, bgcolor = ifvgBearColor, border_style = BoxBorder, border_color = color.new(ifvgBearColor, BorderTransparency), text = plotBoxLabel ? 'Imp.FVG-' : na, text_halign = labelhalign, text_valign = labelvalign, text_size = BoxLabelSize, text_color = BoxLabelColor)
