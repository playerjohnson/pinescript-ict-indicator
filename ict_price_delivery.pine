htf5.candles := candles_5
htf5.imbalances := imbalances_5

var CandleSet htf6=CandleSet.new()
htf6.csettings := SettingsHTF6
htf6.candles := candles_6
htf6.imbalances := imbalances_6

var array<CandleSet> htfSets = array.from(htf1, htf2, htf3, htf4, htf5, htf6)

string group_htfc_style              = "⑬ HTF Candle Styling"
string group_htfc_label              = "⑭ HTF Candle Labels"
string group_htfc_imbalance          = "⑮ HTF Candle Imbalance"
string group_htfc_trace              = "⑯ HTF Candle Trace"

htf1.csettings.show              := input.bool(true, 'HTF 1      ', inline='htf1', group='⑫ HTF Candles')
htf_1=input.timeframe('5', '', inline='htf1', group='⑫ HTF Candles')
htf1.csettings.htf := htf_1
htf1.csettings.max_display       := input.int(4, 'Candles', minval=1, maxval=12, inline='htf1', group='⑫ HTF Candles', tooltip='Requested history. Projected FVG retains at least four candles when space permits (VI retains two); a tight layout budget may show fewer. Twelve caps drawing use when all six sets are enabled.')

htf2.csettings.show              := input.bool(true, 'HTF 2      ', inline='htf2', group='⑫ HTF Candles')
htf_2=input.timeframe('15', '', inline='htf2', group='⑫ HTF Candles')
htf2.csettings.htf := htf_2
htf2.csettings.max_display       := input.int(4, 'Candles', minval=1, maxval=12, inline='htf2', group='⑫ HTF Candles')

htf3.csettings.show              := input.bool(true, 'HTF 3      ', inline='htf3', group='⑫ HTF Candles')
htf_3=input.timeframe('60', '', inline='htf3', group='⑫ HTF Candles')
htf3.csettings.htf := htf_3
htf3.csettings.max_display       := input.int(4, 'Candles', minval=1, maxval=12, inline='htf3', group='⑫ HTF Candles')

htf4.csettings.show              := input.bool(true, 'HTF 4      ', inline='htf4', group='⑫ HTF Candles')
htf_4=input.timeframe('240', '', inline='htf4', group='⑫ HTF Candles')
htf4.csettings.htf := htf_4
htf4.csettings.max_display       := input.int(4, 'Candles', minval=1, maxval=12, inline='htf4', group='⑫ HTF Candles')

htf5.csettings.show              := input.bool(true, 'HTF 5      ', inline='htf5', group='⑫ HTF Candles')
htf_5=input.timeframe('1D', '', inline='htf5', group='⑫ HTF Candles')
htf5.csettings.htf := htf_5
htf5.csettings.max_display       := input.int(4, 'Candles', minval=1, maxval=12, inline='htf5', group='⑫ HTF Candles')

htf6.csettings.show              := input.bool(true, 'HTF 6      ', inline='htf6', group='⑫ HTF Candles')
htf_6=input.timeframe('1W', '', inline='htf6', group='⑫ HTF Candles')
htf6.csettings.htf := htf_6
htf6.csettings.max_display       := input.int(4, 'Candles', minval=1, maxval=12, inline='htf6', group='⑫ HTF Candles')

htfSettings.max_sets               := input.int(3, 'Maximum HTF sets', minval=1, maxval=6, group='⑫ HTF Candles', tooltip='Uses the first valid configured slots in order. Keep the six rows ascending to show the nearest higher timeframes adaptively.')
htfSettings.use_custom_daily       := input.bool(false, 'Custom daily candle open     ', inline='customdaily', group='⑫ HTF Candles')
htfSettings.custom_daily           := input.string('Midnight', '', options=['Midnight', '8:30', '9:30'], inline='customdaily', group='⑫ HTF Candles')
htfSettings.bull_body              := input.color(color.new(color.green, 10), 'Body  ', inline='body', group=group_htfc_style)
htfSettings.bear_body              := input.color(color.new(color.red, 10), '', inline='body', group=group_htfc_style)
htfSettings.bull_border            := input.color(color.new(color.black, 10), 'Borders', inline='borders', group=group_htfc_style)
htfSettings.bear_border            := input.color(color.new(color.black, 10), '', inline='borders', group=group_htfc_style)
htfSettings.bull_wick              := input.color(color.new(color.black, 10), 'Wick  ', inline='wick', group=group_htfc_style)
htfSettings.bear_wick              := input.color(color.new(color.black, 10), '', inline='wick', group=group_htfc_style)

htfSettings.offset                 := input.int(10, 'padding from current candles', minval=1, maxval=100, group=group_htfc_style)
htfSettings.buffer                 := input.int(1, 'space between candles', minval=1, maxval=4, group=group_htfc_style)
htfSettings.htf_buffer             := input.int(3, 'space between Higher Timeframes', minval=1, maxval=10, group=group_htfc_style)
htfSettings.width                  := input.int(1, 'Candle Width', minval=1, maxval=4, group=group_htfc_style, tooltip='Visual width scale. One setting step equals two chart bars so the wick remains centered.') * 2
bool htf_fitLive                   = input.bool(true, 'Fit live candles', inline='htfFit', group=group_htfc_style, tooltip='Fits the nearest configured HTF sets inside Projection bars while honoring the spacing controls. Projected FVG prefers four retained candles and VI prefers two; tight budgets reduce sets or history safely.')
int htf_fitBars                    = input.int(50, 'Projection bars', minval=20, maxval=490, inline='htfFit', group=group_htfc_style)
int htfCandleGap                   = htfSettings.buffer
int htfSetGap                      = htfSettings.htf_buffer

htfSettings.htf_label_show         := input.bool(true, 'HTF Label           ', group=group_htfc_label, inline='HTFlabel')
htfSettings.htf_label_color        := input.color(color.new(color.black, 10), '', group=group_htfc_label, inline='HTFlabel')
htfSettings.htf_label_size         := input.string(size.normal, '', [size.tiny, size.small, size.normal, size.large, size.huge], group=group_htfc_label, inline='HTFlabel')

htfSettings.label_position         := input.string("Bottom", 'Label Positions', options=['Both', 'Top', 'Bottom'], group=group_htfc_label)
htfSettings.label_alignment        := input.string("Align", "Label Alignment", options=['Align', 'Follow Candles'], group=group_htfc_label)

htfSettings.htf_timer_show         := input.bool(true, 'Remaining time      ', inline='timer', group=group_htfc_label)
htfSettings.htf_timer_color        := input.color(color.new(color.black, 10), '', inline='timer', group=group_htfc_label)
htfSettings.htf_timer_size         := input.string(size.small, '', [size.tiny, size.small, size.normal, size.large, size.huge], group=group_htfc_label, inline='timer')

htfSettings.daily_name             := input.bool(false, 'Interval Value        ', group=group_htfc_label, inline='dow')
htfSettings.dow_color              := input.color(color.black , '', group=group_htfc_label, inline='dow')
htfSettings.dow_size               := input.string(size.small, '', [size.tiny, size.small, size.normal, size.large, size.huge], group=group_htfc_label, inline='dow')

htfSettings.fvg_show               := input.bool(true, 'Fair Value Gap   ', group=group_htfc_imbalance, inline='fvg')
htfSettings.fvg_color              := input.color(color.new(color.gray, 80), '', inline='fvg', group=group_htfc_imbalance)

htfSettings.vi_show                := input.bool(false, 'Volume Imbalance', group=group_htfc_imbalance, inline='vi')
htfSettings.vi_color               := input.color(color.new(color.red, 50), '', inline='vi', group=group_htfc_imbalance)

htfSettings.trace_show             := input.bool(false, 'Trace lines', group=group_htfc_trace)
htfSettings.trace_o_color          := input.color(color.new(color.gray, 50), 'Open    ', inline='1', group=group_htfc_trace)
htfSettings.trace_o_style          := input.string('····', '', options=['⎯⎯⎯', '----', '····'], inline='1', group=group_htfc_trace)
htfSettings.trace_o_size           := input.int(1, '', options=[1, 2, 3, 4], inline='1', group=group_htfc_trace)
htfSettings.trace_c_color          := input.color(color.new(color.gray, 50), 'Close    ', inline='2', group=group_htfc_trace)
htfSettings.trace_c_style          := input.string('····', '', options=['⎯⎯⎯', '----', '····'], inline='2', group=group_htfc_trace)
htfSettings.trace_c_size           := input.int(1, '', options=[1, 2, 3, 4], inline='2', group=group_htfc_trace)
htfSettings.trace_h_color          := input.color(color.new(color.gray, 50), 'High     ', inline='3', group=group_htfc_trace)
htfSettings.trace_h_style          := input.string('····', '', options=['⎯⎯⎯', '----', '····'], inline='3', group=group_htfc_trace)
htfSettings.trace_h_size           := input.int(1, '', options=[1, 2, 3, 4], inline='3', group=group_htfc_trace)
htfSettings.trace_l_color          := input.color(color.new(color.gray, 50), 'Low     ', inline='4', group=group_htfc_trace)
htfSettings.trace_l_style          := input.string('····', '', options=['⎯⎯⎯', '----', '····'], inline='4', group=group_htfc_trace)
htfSettings.trace_l_size           := input.int(1, '', options=[1, 2, 3, 4], inline='4', group=group_htfc_trace)
htfSettings.trace_anchor           := input.string('First Timeframe', 'Anchor to', options=['First Timeframe', 'Last Timeframe'], group=group_htfc_trace)

htfSettings.label_show             := input.bool(false, 'Price Label           ', inline='label', group=group_htfc_trace)
htfSettings.label_color            := input.color(color.new(color.black, 10), '', inline='label', group=group_htfc_trace)
htfSettings.label_size             := input.string(size.small, '', [size.tiny, size.small, size.normal, size.large, size.huge], inline='label', group=group_htfc_trace)

var Trace htfTrace=Trace.new()
color htfc_color_transparent = #ffffff00

_htf_LineStyle(string style) =>
	out = switch style
		'----' => line.style_dashed
		'····' => line.style_dotted
		=> line.style_solid
	out

_htf_DayofWeek(int index) =>
	switch
		index == dayofweek.monday => 'M'
		index == dayofweek.tuesday => 'T'
		index == dayofweek.wednesday => 'W'
		index == dayofweek.thursday => 'T'
		index == dayofweek.friday => 'F'
		index == dayofweek.saturday => 'S'
		index == dayofweek.sunday => 'S'
		na(index) => ''

_htf_ValidTimeframe(string HTF) =>
	if timeframe.in_seconds(HTF) >= timeframe.in_seconds('D') and timeframe.in_seconds(HTF) > timeframe.in_seconds()
		true
	else
		n1 = timeframe.in_seconds()
		n2 = timeframe.in_seconds(HTF)
		n1 < n2 and math.round(n2 / n1) == n2 / n1

_htf_CustomAnchor(int _ref, string _mode) =>
	int _h = _mode == '8:30' ? 8 : _mode == '9:30' ? 9 : 0
	int _m = _mode == 'Midnight' ? 0 : 30
	timestamp('America/New_York', year(_ref, 'America/New_York'), month(_ref, 'America/New_York'), dayofmonth(_ref, 'America/New_York'), _h, _m)

_htf_CustomDayKey(int _ref, string _mode) =>
	int _today = _htf_CustomAnchor(_ref, _mode)
	int _key = _today
	if _ref < _today
		int _noon = timestamp('America/New_York', year(_ref, 'America/New_York'), month(_ref, 'America/New_York'), dayofmonth(_ref, 'America/New_York'), 12, 0)
		_key := _htf_CustomAnchor(_noon - 86400000, _mode)
	_key

_htf_NextCustomAnchor(int _ref, string _mode) =>
	int _today = _htf_CustomAnchor(_ref, _mode)
	int _next = _today
	if _ref >= _today
		int _noon = timestamp('America/New_York', year(_ref, 'America/New_York'), month(_ref, 'America/New_York'), dayofmonth(_ref, 'America/New_York'), 12, 0)
		_next := _htf_CustomAnchor(_noon + 86400000, _mode)
	_next

_htf_EffectiveBarEnd() =>
	int _ref = time
	if not na(time_close)
		int _last = math.max(time, time_close - 1)
		_ref := barstate.isrealtime and not barstate.isconfirmed ? math.min(math.max(timenow, time), _last) : _last
	_ref

_htf_RemainingTime(string HTF) =>
	string r = ''
	int _end = htfSettings.use_custom_daily and HTF == '1D' ? _htf_NextCustomAnchor(timenow, htfSettings.custom_daily) : time_close(HTF)
	if barstate.isrealtime and not na(_end) and _end >= timenow
		int timeRemaining = int(math.floor((_end - timenow) / 1000.0))
		int days = int(math.floor(timeRemaining / 86400))
		int hours = int(math.floor((timeRemaining - days * 86400) / 3600))
		int minutes = int(math.floor((timeRemaining - days * 86400 - hours * 3600) / 60))
		int seconds = timeRemaining - days * 86400 - hours * 3600 - minutes * 60

		r := str.tostring(seconds, '00')
		if minutes > 0 or hours > 0 or days > 0
			r := str.tostring(minutes, '00') + ':' + r
		if hours > 0 or days > 0
			r := str.tostring(hours, '00') + ':' + r
		if days > 0
			r := str.tostring(days) + 'D ' + r
	r

_htf_HTFName(string HTF) =>
	formatted = HTF

	seconds = timeframe.in_seconds(HTF)
	if seconds < 60
		formatted := str.tostring(seconds) + 's'
		formatted
	else if seconds / 60 < 60
		formatted := str.tostring(seconds / 60) + 'm'
		formatted
	else if seconds / 60 / 60 < 24
		formatted := str.tostring(seconds / 60 / 60) + 'H'
		formatted
	formatted

_htf_Enabled() =>
	int enabled = 0
	for i = 0 to htfSets.size() - 1
		CandleSet _cs = htfSets.get(i)
		if _cs.csettings.show and _htf_ValidTimeframe(_cs.csettings.htf)
			enabled += 1
	math.min(enabled, htfSettings.max_sets)

_htf_RequiredCandles() =>
	htfSettings.fvg_show ? 4 : htfSettings.vi_show ? 2 : 1

_htf_RightEdge(int _sets, int _candles, int _offset) =>
	_offset + _sets * (_candles * htfSettings.width + (_candles - 1) * htfCandleGap) + (_sets - 1) * htfSetGap

_htf_FitSets(int _sets, int _needed, int _offset, int _budget) =>
	int _fitted = _sets
	while _fitted > 1 and _htf_RightEdge(_fitted, _needed, _offset) > _budget
		_fitted -= 1
	_fitted

_htf_FitLimit(int _sets, int _offset, int _budget) =>
	int _room = _budget - _offset + _sets * htfCandleGap - (_sets - 1) * htfSetGap
	_sets > 0 ? math.max(1, int(math.floor(_room / (_sets * (htfSettings.width + htfCandleGap))))) : 1

_htf_CandleSetHigh(array<Candle> candles, float h) =>
	float _h = h
	if array.size(candles) > 0
		for i = 0 to array.size(candles) - 1 by 1
			Candle c = array.get(candles, i)
			if na(_h) or c.h > _h
				_h := c.h
	_h

_htf_CandleSetLow(array<Candle> candles, float l) =>
	float _l = l
	if array.size(candles) > 0
		for i = 0 to array.size(candles) - 1 by 1
			Candle c = array.get(candles, i)
			if na(_l) or c.l < _l
				_l := c.l
	_l

_htf_CandlesHigh(array<Candle> candles, int last) =>
	float h = na
	int cnt = 0
	for i = 0 to htfSets.size() - 1
		CandleSet _cs = htfSets.get(i)
		if _cs.csettings.show and _htf_ValidTimeframe(_cs.csettings.htf) and cnt < last
			h := _htf_CandleSetHigh(_cs.candles, h)
			cnt += 1
	if array.size(candles) > 0
		for i = 0 to array.size(candles) - 1
			Candle c = array.get(candles, i)
			if na(h) or c.h > h
				h := c.h
	h

_htf_CandlesLow(array<Candle> candles, float h, int last) =>
	float l = h
	int cnt = 0
	for i = 0 to htfSets.size() - 1
		CandleSet _cs = htfSets.get(i)
		if _cs.csettings.show and _htf_ValidTimeframe(_cs.csettings.htf) and cnt < last
			l := _htf_CandleSetLow(_cs.candles, l)
			cnt += 1
	if array.size(candles) > 0
		for i = 0 to array.size(candles) - 1
			Candle c = array.get(candles, i)
			if na(l) or c.l < l
				l := c.l
	l

method Reorder(CandleSet candleSet, int offset, int alignSets) =>
	size = candleSet.candles.size()

	if size > 0
		for i = size - 1 to 0 by 1
			Candle candle = candleSet.candles.get(i)
			t_buffer = offset + (htfSettings.width + htfCandleGap) * (size - i - 1)
			box.set_left(candle.body, bar_index + t_buffer)
			box.set_right(candle.body, bar_index + htfSettings.width + t_buffer)
			line.set_x1(candle.wick_up, bar_index + htfSettings.width / 2 + t_buffer)
			line.set_x2(candle.wick_up, bar_index + htfSettings.width / 2 + t_buffer)
			line.set_x1(candle.wick_down, bar_index + htfSettings.width / 2 + t_buffer)
			line.set_x2(candle.wick_down, bar_index + htfSettings.width / 2 + t_buffer)

			if htfSettings.daily_name
				if not na(candle.dow_label)
					if i == 0 and barstate.isrealtime and not barstate.isconfirmed
						label.delete(candle.dow_label)
						candle.dow_label := label.new(bar_index + htfSettings.width / 2 + t_buffer, candle.h, candle.dow, color = htfc_color_transparent, textcolor = htfSettings.dow_color, style = label.style_label_down, size = htfSettings.dow_size)
					else
						candle.dow_label.set_y(candle.h)
						candle.dow_label.set_x(bar_index + htfSettings.width / 2 + t_buffer)
						candle.dow_label.set_text(candle.dow)
				else
					candle.dow_label := label.new(bar_index + htfSettings.width / 2 + t_buffer, candle.h, candle.dow, color = htfc_color_transparent, textcolor = htfSettings.dow_color, style = label.style_label_down, size = htfSettings.dow_size)

	float top = na
	float bottom = na

	if htfSettings.label_alignment == 'Align'
		top := _htf_CandlesHigh(candleSet.candles, alignSets)
		bottom := _htf_CandlesLow(candleSet.candles, top, alignSets)
	if htfSettings.label_alignment == 'Follow Candles'
		top := _htf_CandleSetHigh(candleSet.candles, na)
		bottom := _htf_CandleSetLow(candleSet.candles, top)

	int left = bar_index + offset + int(math.floor(((htfSettings.width + htfCandleGap) * (size - 1) + htfSettings.width) / 2.0))

	if htfSettings.htf_label_show
		string _remaining = _htf_RemainingTime(candleSet.csettings.htf)
		bool _showTimer = htfSettings.htf_timer_show and str.length(_remaining) > 0
		string lblt = _htf_HTFName(candleSet.csettings.htf)
		string lbll = lblt
		if _showTimer
			lblt := lblt + '\n'
			lbll := '\n' + lbll
		if htfSettings.daily_name
			lblt := lblt + '\n'

		string tmr = '(' + _remaining + ')' + (htfSettings.daily_name ? '\n' : '')
		if not _showTimer
			if not na(candleSet.tfTimerTop)
				label.delete(candleSet.tfTimerTop)
				candleSet.tfTimerTop := na
			if not na(candleSet.tfTimerBottom)
				label.delete(candleSet.tfTimerBottom)
				candleSet.tfTimerBottom := na
		if htfSettings.label_position == 'Both' or htfSettings.label_position == 'Top'

			if not na(candleSet.tfNameTop)
				if barstate.isrealtime and not barstate.isconfirmed
					label.delete(candleSet.tfNameTop)
					candleSet.tfNameTop := label.new(left, top, lblt, color = htfc_color_transparent, textcolor = htfSettings.htf_label_color, style = label.style_label_down, size = htfSettings.htf_label_size)
				else
					candleSet.tfNameTop.set_xy(left, top)
					candleSet.tfNameTop.set_text(lblt)
			else
				candleSet.tfNameTop := label.new(left, top, lblt, color = htfc_color_transparent, textcolor = htfSettings.htf_label_color, style = label.style_label_down, size = htfSettings.htf_label_size)
			if _showTimer
				if not na(candleSet.tfTimerTop)
					if barstate.isrealtime and not barstate.isconfirmed
						label.delete(candleSet.tfTimerTop)
						candleSet.tfTimerTop := label.new(left, top, tmr, color = htfc_color_transparent, textcolor = htfSettings.htf_timer_color, style = label.style_label_down, size = htfSettings.htf_timer_size)
					else
						candleSet.tfTimerTop.set_xy(left, top)
						candleSet.tfTimerTop.set_text(tmr)
				else
					candleSet.tfTimerTop := label.new(left, top, tmr, color = htfc_color_transparent, textcolor = htfSettings.htf_timer_color, style = label.style_label_down, size = htfSettings.htf_timer_size)

		if htfSettings.label_position == 'Both' or htfSettings.label_position == 'Bottom'
			if not na(candleSet.tfNameBottom)
				if barstate.isrealtime and not barstate.isconfirmed
					label.delete(candleSet.tfNameBottom)
					candleSet.tfNameBottom := label.new(left, bottom, lbll, color = htfc_color_transparent, textcolor = htfSettings.htf_label_color, style = label.style_label_up, size = htfSettings.htf_label_size)
				else
					candleSet.tfNameBottom.set_xy(left, bottom)
					candleSet.tfNameBottom.set_text(lbll)
			else
				candleSet.tfNameBottom := label.new(left, bottom, lbll, color = htfc_color_transparent, textcolor = htfSettings.htf_label_color, style = label.style_label_up, size = htfSettings.htf_label_size)
			if _showTimer
				if not na(candleSet.tfTimerBottom)
					if barstate.isrealtime and not barstate.isconfirmed
						label.delete(candleSet.tfTimerBottom)
						candleSet.tfTimerBottom := label.new(left, bottom, tmr, color = htfc_color_transparent, textcolor = htfSettings.htf_timer_color, style = label.style_label_up, size = htfSettings.htf_timer_size)
					else
						candleSet.tfTimerBottom.set_xy(left, bottom)
						candleSet.tfTimerBottom.set_text(tmr)
				else
					candleSet.tfTimerBottom := label.new(left, bottom, tmr, color = htfc_color_transparent, textcolor = htfSettings.htf_timer_color, style = label.style_label_up, size = htfSettings.htf_timer_size)

	candleSet

method UpsertImbalance(CandleSet candleSet, int _key, int _left, float _top, int _right, float _bottom, color _fill, bool _commit) =>
	int _found = -1
	if candleSet.imbalances.size() > 0
		for i = 0 to candleSet.imbalances.size() - 1
			if candleSet.imbalances.get(i).idx == _key
				_found := i
	bool _created = false
	if _found >= 0
		Imbalance imb = candleSet.imbalances.get(_found)
		box.set_left(imb.b, _left)
		box.set_right(imb.b, _right)
		box.set_top(imb.b, _top)
		box.set_bottom(imb.b, _bottom)
		box.set_bgcolor(imb.b, _fill)
		box.set_border_color(imb.b, htfc_color_transparent)
		f_gradeSync(imb.grade, imb.b)
	else if _commit
		Imbalance imb = Imbalance.new()
		imb.idx := _key
		imb.b := box.new(_left, _top, _right, _bottom, bgcolor = _fill, border_color = htfc_color_transparent, xloc = xloc.bar_index)
		line _ce = cefvg and _key > 0 ? line.new(_left, math.avg(_top, _bottom), _right, math.avg(_top, _bottom), xloc=xloc.bar_index, style=celinetype, color=color.new(_fill, cetransparency)) : na
		imb.grade := f_gradeNew(_ce, _top, _bottom)
		candleSet.imbalances.push(imb)
		_created := true
	_created

method FindImbalance(CandleSet candleSet) =>
	if barstate.isrealtime or barstate.islast or barstate.islastconfirmedhistory
		bool _commit = barstate.islastconfirmedhistory or barstate.isconfirmed
		array<int> _seen = array.new<int>()
		array<int> _viSkip = array.new<int>()
		bool _created = false

		if candleSet.candles.size() > 2 and htfSettings.fvg_show
			for i = 0 to candleSet.candles.size() - 3
				Candle candle1 = candleSet.candles.get(i)
				Candle candle2 = candleSet.candles.get(i + 2)
				Candle candle3 = candleSet.candles.get(i + 1)
				int _xLeft = math.min(box.get_left(candle1.body), box.get_left(candle2.body))
				int _xRight = math.max(box.get_right(candle1.body), box.get_right(candle2.body))
				int _key = candle1.o_time

				if candle1.l > candle2.h and math.min(candle1.o, candle1.c) > math.max(candle2.o, candle2.c)
					float _fTop = candle1.l
					float _fBot = candle2.h
					if fvgAnchorVI
						bool _vi01 = math.min(candle1.o, candle1.c) != math.max(candle3.o, candle3.c)
						bool _vi12 = math.min(candle3.o, candle3.c) != math.max(candle2.o, candle2.c)
						if _vi01
							_fTop := math.max(_fTop, math.max(candle1.o, candle3.c))
							_fBot := math.min(_fBot, math.min(candle1.o, candle3.c))
							_viSkip.push(i)
						if _vi12
							_fTop := math.max(_fTop, math.max(candle3.o, candle2.c))
							_fBot := math.min(_fBot, math.min(candle3.o, candle2.c))
							_viSkip.push(i + 1)
					_seen.push(_key)
					bool _wasCreated = candleSet.UpsertImbalance(_key, _xLeft, _fTop, _xRight, _fBot, htfSettings.fvg_color, _commit)
					_created := _created or _wasCreated
				if candle1.h < candle2.l and math.max(candle1.o, candle1.c) < math.min(candle2.o, candle2.c)
					float _fTop = candle2.l
					float _fBot = candle1.h
					if fvgAnchorVI
						bool _vi01 = math.max(candle1.o, candle1.c) != math.min(candle3.o, candle3.c)
						bool _vi12 = math.max(candle3.o, candle3.c) != math.min(candle2.o, candle2.c)
						if _vi01
							_fTop := math.max(_fTop, math.max(candle3.c, candle1.o))
							_fBot := math.min(_fBot, math.min(candle3.c, candle1.o))
							_viSkip.push(i)
						if _vi12
							_fTop := math.max(_fTop, math.max(candle2.c, candle3.o))
							_fBot := math.min(_fBot, math.min(candle2.c, candle3.o))
							_viSkip.push(i + 1)
					_seen.push(_key)
					bool _wasCreated = candleSet.UpsertImbalance(_key, _xLeft, _fTop, _xRight, _fBot, htfSettings.fvg_color, _commit)
					_created := _created or _wasCreated

		if candleSet.candles.size() > 1 and htfSettings.vi_show
			for i = 0 to candleSet.candles.size() - 2
				if fvgAnchorVI and _viSkip.includes(i)
					continue
				Candle candle1 = candleSet.candles.get(i)
				Candle candle2 = candleSet.candles.get(i + 1)
				int _xLeft = math.min(box.get_left(candle1.body), box.get_left(candle2.body))
				int _xRight = math.max(box.get_right(candle1.body), box.get_right(candle2.body))
				int _key = -candle1.o_time
				if candle1.l < candle2.h and math.min(candle1.o, candle1.c) > math.max(candle2.o, candle2.c)
					_seen.push(_key)
					bool _wasCreated = candleSet.UpsertImbalance(_key, _xLeft, math.min(candle1.o, candle1.c), _xRight, math.max(candle2.o, candle2.c), htfSettings.vi_color, _commit)
					_created := _created or _wasCreated
				if candle1.h > candle2.l and math.max(candle1.o, candle1.c) < math.min(candle2.o, candle2.c)
					_seen.push(_key)
					bool _wasCreated = candleSet.UpsertImbalance(_key, _xLeft, math.min(candle2.o, candle2.c), _xRight, math.max(candle1.o, candle1.c), htfSettings.vi_color, _commit)
					_created := _created or _wasCreated

		if _commit and candleSet.imbalances.size() > 0
			for i = candleSet.imbalances.size() - 1 to 0
				Imbalance imb = candleSet.imbalances.get(i)
				if not _seen.includes(imb.idx)
					f_gradeDelete(imb.grade)
					box.delete(imb.b)
					candleSet.imbalances.remove(i)

		if _created and candleSet.candles.size() > 0
			for i = 0 to candleSet.candles.size() - 1
				Candle candle = candleSet.candles.get(i)
				box temp = box.copy(candle.body)
				box.delete(candle.body)
				candle.body := temp
	candleSet

method Monitor(CandleSet candleSet, int displayLimit) =>
	bool _custom1D = htfSettings.use_custom_daily and candleSet.csettings.htf == '1D'
	int HTFBarTime = _custom1D ? _htf_CustomDayKey(_htf_EffectiveBarEnd(), htfSettings.custom_daily) : time(candleSet.csettings.htf)
	bool isNewHTFCandle = not na(HTFBarTime) and (na(candleSet.prevBarTime) or HTFBarTime != candleSet.prevBarTime)
	candleSet.prevBarTime := HTFBarTime
	if isNewHTFCandle
		Candle candle = Candle.new()
		candle.o := open
		candle.c := close
		candle.h := high
		candle.l := low
		candle.o_time := _custom1D ? HTFBarTime : time
		candle.o_idx := bar_index
		candle.c_idx := bar_index
		candle.h_idx := bar_index
		candle.l_idx := bar_index
		candle.dow := switch
			candleSet.csettings.htf == '1D' =>
				int _dow = _custom1D ? dayofweek(candle.o_time, 'America/New_York') : dayofweek(time_tradingday, 'UTC')
				_htf_DayofWeek(_dow)
			str.tonumber(candleSet.csettings.htf) < 60 =>
				str.format_time(candle.o_time, 'm', 'America/New_York')
			str.tonumber(candleSet.csettings.htf) >= 60 =>
				str.format_time(candle.o_time, 'H', 'America/New_York')
			candleSet.csettings.htf == '1M' =>
				str.format_time(candle.o_time, 'M', 'America/New_York')
			=>
				''
		bull = candle.c > candle.o

		candle.body := box.new(bar_index, math.max(candle.o, candle.c), bar_index + 2, math.min(candle.o, candle.c), bull ? htfSettings.bull_border : htfSettings.bear_border, 1, bgcolor = bull ? htfSettings.bull_body : htfSettings.bear_body)
		candle.wick_up := line.new(bar_index + 1, candle.h, bar_index, math.max(candle.o, candle.c), color = bull ? htfSettings.bull_wick : htfSettings.bear_wick)
		candle.wick_down := line.new(bar_index + 1, math.min(candle.o, candle.c), bar_index, candle.l, color = bull ? htfSettings.bull_wick : htfSettings.bear_wick)

		candleSet.candles.unshift(candle)

		if candleSet.candles.size() > displayLimit
			Candle delCandle = array.pop(candleSet.candles)
			box.delete(delCandle.body)
			line.delete(delCandle.wick_up)
			line.delete(delCandle.wick_down)
			delCandle.dow_label.delete()

	candleSet

_htf_traceUpd(_ln, _lb, _srcIdx, _srcVal, _x2, _bRight, _clr, _style, _sz) =>
	line _oLn = _ln
	label _oLb = _lb
	if not na(_srcIdx) and not na(_srcVal)
		int _safeSrcIdx = math.max(_srcIdx, bar_index - 4999)
		if na(_oLn)
			_oLn := line.new(_safeSrcIdx, _srcVal, _x2, _srcVal, xloc=xloc.bar_index, color=_clr, style=_htf_LineStyle(_style), width=_sz)
		else if barstate.isrealtime and not barstate.isconfirmed
			line.delete(_oLn)
			_oLn := line.new(_safeSrcIdx, _srcVal, _x2, _srcVal, xloc=xloc.bar_index, color=_clr, style=_htf_LineStyle(_style), width=_sz)
		else
			line.set_xy1(_oLn, _safeSrcIdx, _srcVal)
			line.set_xy2(_oLn, _x2, _srcVal)
			_oLn
		if htfSettings.label_show
			if na(_oLb)
				_oLb := label.new(_bRight, _srcVal, str.tostring(_srcVal), textalign=text.align_center, style=label.style_label_left, size=htfSettings.label_size, color=htfc_color_transparent, textcolor=htfSettings.label_color)
			else if barstate.isrealtime and not barstate.isconfirmed
				label.delete(_oLb)
				_oLb := label.new(_bRight, _srcVal, str.tostring(_srcVal), textalign=text.align_center, style=label.style_label_left, size=htfSettings.label_size, color=htfc_color_transparent, textcolor=htfSettings.label_color)
			else
				label.set_xy(_oLb, _bRight, _srcVal)
				label.set_text(_oLb, str.tostring(_srcVal))
				_oLb
	[_oLn, _oLb]

method Update(CandleSet candleSet, int offset, bool showTrace, int alignSets) =>
	if candleSet.candles.size() > 0
		Candle candle = candleSet.candles.first()
		candle.h_idx := high > candle.h ? bar_index : candle.h_idx
		candle.h := high > candle.h ? high : candle.h
		candle.l_idx := low < candle.l ? bar_index : candle.l_idx
		candle.l := low < candle.l ? low : candle.l
		candle.c := close
		candle.c_idx := bar_index

		bull = candle.c > candle.o

		float _bodyTop = math.max(candle.o, candle.c)
		float _bodyBottom = math.min(candle.o, candle.c)
		color _bodyColor = bull ? htfSettings.bull_body : htfSettings.bear_body
		color _borderColor = bull ? htfSettings.bull_border : htfSettings.bear_border
		color _wickColor = bull ? htfSettings.bull_wick : htfSettings.bear_wick
		if barstate.isrealtime and not barstate.isconfirmed
			int _tBuffer = offset + (htfSettings.width + htfCandleGap) * (candleSet.candles.size() - 1)
			int _left = bar_index + _tBuffer
			int _right = _left + htfSettings.width
			int _wickX = _left + htfSettings.width / 2
			box.delete(candle.body)
			line.delete(candle.wick_up)
			line.delete(candle.wick_down)
			candle.body := box.new(_left, _bodyTop, _right, _bodyBottom, _borderColor, 1, bgcolor = _bodyColor)
			candle.wick_up := line.new(_wickX, candle.h, _wickX, _bodyTop, color = _wickColor)
			candle.wick_down := line.new(_wickX, _bodyBottom, _wickX, candle.l, color = _wickColor)
		else
			box.set_top(candle.body, _bodyTop)
			box.set_bottom(candle.body, _bodyBottom)
			box.set_bgcolor(candle.body, _bodyColor)
			box.set_border_color(candle.body, _borderColor)
			line.set_color(candle.wick_up, _wickColor)
			line.set_color(candle.wick_down, _wickColor)
			line.set_y1(candle.wick_up, candle.h)
			line.set_y2(candle.wick_up, _bodyTop)
			line.set_y1(candle.wick_down, candle.l)
			line.set_y2(candle.wick_down, _bodyBottom)

		if barstate.isrealtime or barstate.islast or barstate.islastconfirmedhistory
			candleSet.Reorder(offset, alignSets)
			if htfSettings.trace_show and showTrace
				int _bR = box.get_right(candle.body)
				int _bL = box.get_left(candle.body)
				[_to, _to_l] = _htf_traceUpd(htfTrace.o, htfTrace.o_l, candle.o_idx, candle.o, _bL, _bR, htfSettings.trace_o_color, htfSettings.trace_o_style, htfSettings.trace_o_size)
				htfTrace.o := _to, htfTrace.o_l := _to_l
				[_tc, _tc_l] = _htf_traceUpd(htfTrace.c, htfTrace.c_l, candle.c_idx, candle.c, _bL, _bR, htfSettings.trace_c_color, htfSettings.trace_c_style, htfSettings.trace_c_size)
				htfTrace.c := _tc, htfTrace.c_l := _tc_l
				[_th, _th_l] = _htf_traceUpd(htfTrace.h, htfTrace.h_l, candle.h_idx, candle.h, line.get_x1(candle.wick_up), _bR, htfSettings.trace_h_color, htfSettings.trace_h_style, htfSettings.trace_h_size)
				htfTrace.h := _th, htfTrace.h_l := _th_l
				[_tl, _tl_l] = _htf_traceUpd(htfTrace.l, htfTrace.l_l, candle.l_idx, candle.l, line.get_x1(candle.wick_down), _bR, htfSettings.trace_l_color, htfSettings.trace_l_style, htfSettings.trace_l_size)
				htfTrace.l := _tl, htfTrace.l_l := _tl_l
	candleSet

int htfCnt = 0
int htfAvailable = _htf_Enabled()
int htfBudget = htf_fitLive ? math.min(htf_fitBars, 490) : 490
int htfRequired = _htf_RequiredCandles()
int htfMinSpan = htfRequired * htfSettings.width + (htfRequired - 1) * htfCandleGap
int htfLayoutOffset = math.max(1, math.min(htfSettings.offset, math.max(1, htfBudget - htfMinSpan)))
int htfLast = htfAvailable > 0 ? _htf_FitSets(htfAvailable, htfRequired, htfLayoutOffset, htfBudget) : 0
int htfDisplayLimit = htfLast > 0 ? _htf_FitLimit(htfLast, htfLayoutOffset, htfBudget) : 1
int htfOffset = htfLayoutOffset
if ENABLE_HTF_CANDLES
	for i = 0 to htfSets.size() - 1
		CandleSet _cs = htfSets.get(i)
		if _cs.csettings.show and _htf_ValidTimeframe(_cs.csettings.htf) and htfCnt < htfLast
			bool showTrace = (htfSettings.trace_anchor == 'First Timeframe' and htfCnt == 0) or (htfSettings.trace_anchor == 'Last Timeframe' and htfCnt == htfLast - 1)
			int _display = math.min(htfDisplayLimit, math.max(htfRequired, _cs.csettings.max_display))
			_cs.Monitor(_display).Update(htfOffset, showTrace, htfLast).FindImbalance()
			htfCnt += 1
			htfOffset += _cs.candles.size() * htfSettings.width + (_cs.candles.size() > 0 ? (_cs.candles.size() - 1) * htfCandleGap : 0) + htfSetGap

// ===== ㉙ HTF FVG Overlay (adapted from MTF FVG x2 [MK] by @malk1903, MPL-2.0) =====
string group_mtf_fvg = "㉙ HTF FVG Overlay"
string mtf_fvgTf=input.timeframe("60", "Timeframe", group=group_mtf_fvg, inline="mf1", tooltip="Must be higher than the chart timeframe. Uses only fully closed HTF candles.")
string mtf_fvgFill=input.string("Full Fill", "Fill", options=["Touch", "Half Fill", "Full Fill"], group=group_mtf_fvg, inline="mf1", tooltip="Wick retirement for normal/implied zones. With ⑥ Inverse + Engulf, normal zones instead flip after a confirmed chart close through; inverse zones invalidate on the opposite close.")
int mtf_fvgMax=input.int(12, "Max Zones", minval=1, maxval=20, group=group_mtf_fvg, inline="mf2", tooltip="Combined normal + implied + inverse cap. Each zone uses one box and one 50% line when ⑥ CE is enabled.")

color mtf_fvgBullColor=input.color(color.new(color.green, 90), 'Normal Colours', group=group_mtf_fvg, inline='mf3', tooltip='Bullish and bearish colours for normal FVGs from the selected higher timeframe. Implied and inverse zones keep their existing colours.')
color mtf_fvgBearColor=input.color(color.new(color.red, 90), '', group=group_mtf_fvg, inline='mf3')

type MtfFvgZone
	box bx
	GradeLines grade
	bool bull
	int kind

var array<MtfFvgZone> mtfFvgZones=array.new<MtfFvgZone>()

f_mtfFvgDelete(MtfFvgZone _z) =>
	box.delete(_z.bx)
	f_gradeDelete(_z.grade)

f_mtfFvgAdd(array<MtfFvgZone> _zones, bool _bull, int _kind, float _top, float _bottom, int _left, int _right, string _tf) =>
	while _zones.size() >= mtf_fvgMax
		MtfFvgZone _old = _zones.shift()
		f_mtfFvgDelete(_old)
	color _clr = _kind == 1 ? (_bull ? ifvgBullColor : ifvgBearColor) : (_bull ? mtf_fvgBullColor : mtf_fvgBearColor)
	string _tag = _kind == 1 ? " Imp.FVG" : " FVG"
	string _txt = plotBoxLabel ? _htf_HTFName(_tf) + _tag + (_bull ? "+" : "-") : na
	box _bx = box.new(left=_left, top=_top, right=_right, bottom=_bottom, xloc=xloc.bar_time, bgcolor=_clr, border_color=color.new(_clr, BorderTransparency), border_style=BoxBorder, border_width=1, text=_txt, text_halign=labelhalign, text_valign=labelvalign, text_size=BoxLabelSize, text_color=BoxLabelColor)
	line _ce = cefvg ? line.new(_left, math.avg(_top, _bottom), _right, math.avg(_top, _bottom), xloc=xloc.bar_time, style=celinetype, color=color.new(_clr, cetransparency)) : na
	GradeLines _grade = f_gradePinnedNew(_ce, _top, _bottom)
	_zones.push(MtfFvgZone.new(_bx, _grade, _bull, _kind))

f_mtfFvgSnapshot() =>
	int _dir = isFvgUp(1) ? 1 : isFvgDown(1) ? -1 : 0
	float _top = _dir == 1 ? low[1] : _dir == -1 ? low[3] : na
	float _bottom = _dir == 1 ? high[3] : _dir == -1 ? high[1] : na
	if _dir != 0 and fvgAnchorVI
		if _anyVI(1)
			_top := math.max(_top, math.max(open[1], close[2]))
			_bottom := math.min(_bottom, math.min(open[1], close[2]))
		if _anyVI(2)
			_top := math.max(_top, math.max(open[2], close[3]))
			_bottom := math.min(_bottom, math.min(open[2], close[3]))
	int _impDir = showifvg and isBuIFvg(1) ? 1 : showifvg and isBeIFvg(1) ? -1 : 0
	float _impTop = _impDir == 1 ? (math.min(open[1], close[1]) + low[1]) / 2 : _impDir == -1 ? (math.min(open[3], close[3]) + low[3]) / 2 : na
	float _impBottom = _impDir == 1 ? (high[3] + math.max(open[3], close[3])) / 2 : _impDir == -1 ? (math.max(open[1], close[1]) + high[1]) / 2 : na
	[time[3], _dir, _top, _bottom, _impDir, _impTop, _impBottom]

if ENABLE_MTF_FVG and timeframe.in_seconds(mtf_fvgTf) > timeframe.in_seconds()
	[_t3, _dir, _topNew, _bottomNew, _impDir, _impTop, _impBottom] = request.security(syminfo.tickerid, mtf_fvgTf, f_mtfFvgSnapshot(), lookahead=barmerge.lookahead_on)
	int _rightTime = nz(time_close, time)
	if timeframe.change(mtf_fvgTf) and not na(_t3)
		if _dir != 0
			f_mtfFvgAdd(mtfFvgZones, _dir == 1, 0, _topNew, _bottomNew, _t3, _rightTime, mtf_fvgTf)
		if _impDir != 0
			f_mtfFvgAdd(mtfFvgZones, _impDir == 1, 1, _impTop, _impBottom, _t3, _rightTime, mtf_fvgTf)
	if mtfFvgZones.size() > 0
		for i = mtfFvgZones.size() - 1 to 0 by 1
			MtfFvgZone _z = mtfFvgZones.get(i)
			float _top = box.get_top(_z.bx)
			float _bottom = box.get_bottom(_z.bx)
			float _fillLevel = switch mtf_fvgFill
				"Touch" => _z.bull ? _top : _bottom
				"Half Fill" => math.avg(_top, _bottom)
				=> _z.bull ? _bottom : _top
			bool _filled = _z.bull ? low <= _fillLevel : high >= _fillLevel
			bool _remove = false
			if barstate.isconfirmed
				if _z.kind == 2
					_remove := _z.bull ? close < _bottom : close > _top
				else if _z.kind == 0 and Inversefvgmode and fvgmitigationtype == "Engulf"
					bool _broken = _z.bull ? close < _bottom : close > _top
					if _broken
						_z.bull := not _z.bull
						_z.kind := 2
						color _invClr = _z.bull ? buinvfvgcolor : beinvfvgcolor
						box.set_bgcolor(_z.bx, _invClr)
						box.set_border_color(_z.bx, color.new(_invClr, BorderTransparency))
						box.set_text(_z.bx, plotBoxLabel ? _htf_HTFName(mtf_fvgTf) + " Inv.FVG" + (_z.bull ? "+" : "-") : '')
						f_gradePromote(_z.grade, _top, _bottom)
						f_gradeColor(_z.grade, color.new(_invClr, cetransparency))
				else
					_remove := _filled
			if _remove
				f_mtfFvgDelete(_z)
				mtfFvgZones.remove(i)
				continue
			box.set_right(_z.bx, _rightTime)
			f_gradeX2(_z.grade, _rightTime)
			_top := box.get_top(_z.bx)
			_bottom := box.get_bottom(_z.bx)
			bool _entered = _z.bull ? low <= _top : high >= _bottom
			if HighlightBox and _entered
				color _touchClr = _z.kind == 1 ? (_z.bull ? ifvgBullColor : ifvgBearColor) : _z.kind == 2 ? (_z.bull ? buinvfvgcolor : beinvfvgcolor) : (_z.bull ? mtf_fvgBullColor : mtf_fvgBearColor)
				_applyHighlight(_z.bx, _touchClr)
			if fvgQuality and barstate.isconfirmed and _z.kind == 0
				f_fvgQualityTick(_z.grade, _z.bx, plotBoxLabel ? _htf_HTFName(mtf_fvgTf) + ' FVG' + (_z.bull ? '+' : '-') : '')
