ec_requestData() =>
	[request.seed('seed_toodegrees_toogit', 'TOODEGREES_FOREX_FACTORY_SLOT_1', str.tostring(open) + ',' + str.tostring(high) + ',' + str.tostring(low) + ',' + str.tostring(close) + ',' + str.tostring(volume), ignore_invalid_symbol=true),
	 request.seed('seed_toodegrees_toogit', 'TOODEGREES_FOREX_FACTORY_SLOT_2', str.tostring(open) + ',' + str.tostring(high) + ',' + str.tostring(low) + ',' + str.tostring(close) + ',' + str.tostring(volume), ignore_invalid_symbol=true),
	 request.seed('seed_toodegrees_toogit', 'TOODEGREES_FOREX_FACTORY_SLOT_3', str.tostring(open) + ',' + str.tostring(high) + ',' + str.tostring(low) + ',' + str.tostring(close) + ',' + str.tostring(volume), ignore_invalid_symbol=true),
	 request.seed('seed_toodegrees_toogit', 'TOODEGREES_FOREX_FACTORY_SLOT_4', str.tostring(open) + ',' + str.tostring(high) + ',' + str.tostring(low) + ',' + str.tostring(close) + ',' + str.tostring(volume), ignore_invalid_symbol=true),
	 request.seed('seed_toodegrees_toogit', 'TOODEGREES_FOREX_FACTORY_SLOT_5', str.tostring(open) + ',' + str.tostring(high) + ',' + str.tostring(low) + ',' + str.tostring(close) + ',' + str.tostring(volume), ignore_invalid_symbol=true),
	 request.seed('seed_toodegrees_toogit', 'TOODEGREES_FOREX_FACTORY_SLOT_6', str.tostring(open) + ',' + str.tostring(high) + ',' + str.tostring(low) + ',' + str.tostring(close) + ',' + str.tostring(volume), ignore_invalid_symbol=true),
	 request.seed('seed_toodegrees_toogit', 'TOODEGREES_FOREX_FACTORY_SLOT_7', str.tostring(open) + ',' + str.tostring(high) + ',' + str.tostring(low) + ',' + str.tostring(close) + ',' + str.tostring(volume), ignore_invalid_symbol=true),
	 request.seed('seed_toodegrees_toogit', 'TOODEGREES_FOREX_FACTORY_SLOT_8', str.tostring(open) + ',' + str.tostring(high) + ',' + str.tostring(low) + ',' + str.tostring(close) + ',' + str.tostring(volume), ignore_invalid_symbol=true),
	 request.seed('seed_toodegrees_toogit', 'TOODEGREES_FOREX_FACTORY_SLOT_9', str.tostring(open) + ',' + str.tostring(high) + ',' + str.tostring(low) + ',' + str.tostring(close) + ',' + str.tostring(volume), ignore_invalid_symbol=true)]

method ec_processData(ffUtil.News[] _news, string _s1, string _s2, string _s3, string _s4, string _s5, string _s6, string _s7, string _s8, string _s9) =>
	if not na(_s1)
		ffDec.readNews(_news, _s1)
	if not na(_s2)
		ffDec.readNews(_news, _s2)
	if not na(_s3)
		ffDec.readNews(_news, _s3)
	if not na(_s4)
		ffDec.readNews(_news, _s4)
	if not na(_s5)
		ffDec.readNews(_news, _s5)
	if not na(_s6)
		ffDec.readNews(_news, _s6)
	if not na(_s7)
		ffDec.readNews(_news, _s7)
	if not na(_s8)
		ffDec.readNews(_news, _s8)
	if not na(_s9)
		ffDec.readNews(_news, _s9)

f_ecImpactRank(color _c) =>
	_c == color.red ? 3 : _c == color.orange ? 2 : _c == color.yellow ? 1 : 0

f_ecCloneNews(array<ffUtil.News> _source) =>
	array<ffUtil.News> _clone=array.new<ffUtil.News>()
	if _source.size() > 0
		for i=0 to _source.size() - 1
			ffUtil.News _event=_source.get(i)
			_clone.push(ffUtil.News.new(_event.dow, _event.dat, _event._t, _event.tod, _event.cur, _event.imp, _event.ttl, _event.tmst, _event.ln))
	_clone

f_ecTodayNews(array<ffUtil.News> _week, array<ffUtil.News> _day, string _timezone) =>
	_day.clear()
	int _year=year(time, _timezone)
	int _month=month(time, _timezone)
	int _date=dayofmonth(time, _timezone)
	if _week.size() > 0
		for i=0 to _week.size() - 1
			ffUtil.News _event=_week.get(i)
			if not na(_event.tmst) and year(_event.tmst, _timezone) == _year and month(_event.tmst, _timezone) == _month and dayofmonth(_event.tmst, _timezone) == _date
				_day.push(_event)
	_day

f_ecDrawLines(array<ffUtil.News> _news, array<line> _lines, array<int> _times, int _transparency, string _style, int _cap) =>
	array<int> _eventTimes=array.new_int()
	array<color> _eventColors=array.new_color()
	if _news.size() > 0
		for i=_news.size() - 1 to 0
			ffUtil.News _event=_news.get(i)
			if not na(_event.tmst)
				int _adj=_event.tmst
				int _idx=_eventTimes.indexof(_adj)
				if _idx == -1
					_eventTimes.push(_adj)
					_eventColors.push(_event.imp)
				else if f_ecImpactRank(_event.imp) > f_ecImpactRank(_eventColors.get(_idx))
					_eventColors.set(_idx, _event.imp)
	if _eventTimes.size() > 0
		for i=0 to _eventTimes.size() - 1
			int _eventTime=_eventTimes.get(i)
			if _times.indexof(_eventTime) == -1
				while _lines.size() >= _cap
					line.delete(_lines.shift())
					_times.shift()
				if line.all.size() < 490
					line _eventLine=line.new(_eventTime, low, _eventTime, high, xloc.bar_time, extend.both, color.new(_eventColors.get(i), _transparency), style=_style)
					_lines.push(_eventLine)
					_times.push(_eventTime)
	while _lines.size() > _cap
		line.delete(_lines.shift())
		_times.shift()

f_ecDrawLabel(array<ffUtil.News> _news, array<label> _labels, array<int> _times, string _placement, string _size, bool _outline, int _cap) =>
	string _tooltip=''
	color _impact=color.white
	if _news.size() > 0
		for i=0 to _news.size() - 1
			ffUtil.News _event=_news.get(i)
			if _event.tmst >= time and _event.tmst < time_close and (not barstate.isrealtime or timenow >= _event.tmst)
				_tooltip += (_tooltip == '' ? '' : '\n') + _event.ttl + ' (' + _event.cur + ')'
				if f_ecImpactRank(_event.imp) > f_ecImpactRank(_impact)
					_impact := _event.imp
	if _tooltip != ''
		bool _below=_placement == 'Below' or (_placement == 'Auto' and open < close)
		int _labelIdx=_times.indexof(time)
		label _eventLabel=_labelIdx == -1 ? label(na) : _labels.get(_labelIdx)
		if na(_eventLabel)
			while _labels.size() >= _cap
				label.delete(_labels.shift())
				_times.shift()
			if label.all.size() < 490
				_eventLabel := label.new(time, _below ? low : high, _outline ? '◉' : '●', xloc=xloc.bar_time, color=color.new(color.black, 100), style=_below ? label.style_label_up : label.style_label_down, textcolor=_impact, size=_size, tooltip=_tooltip)
		if not na(_eventLabel)
			label.set_xy(_eventLabel, time, _below ? low : high)
			label.set_text(_eventLabel, _outline ? '◉' : '●')
			label.set_style(_eventLabel, _below ? label.style_label_up : label.style_label_down)
			label.set_textcolor(_eventLabel, _impact)
			label.set_size(_eventLabel, _size)
			label.set_tooltip(_eventLabel, _tooltip)
		if _labelIdx == -1 and not na(_eventLabel)
			_labels.push(_eventLabel)
			_times.push(time)
	while _labels.size() > _cap
		label.delete(_labels.shift())
		_times.shift()

f_ecPruneDrawings(array<line> _lines, array<int> _lineTimes, array<label> _labels, array<int> _labelTimes, string _historyMode, int _days, string _lineMode, string _timezone) =>
	int _calendarMidnight=timestamp(_timezone, year(time, _timezone), month(time, _timezone), dayofmonth(time, _timezone), 0, 0)
	int _delimiter=_historyMode == 'Today' ? _calendarMidnight : _historyMode == 'This Week' ? time('W') : time - _days * 86400000
	int _futureCutoff=barstate.isrealtime ? timenow : time_close
	if _lines.size() > 0
		for i=_lines.size() - 1 to 0
			int _eventTime=_lineTimes.get(i)
			if _eventTime < _delimiter or (_lineMode == 'Future' and _eventTime <= _futureCutoff)
				line.delete(_lines.remove(i))
				_lineTimes.remove(i)
	if _labels.size() > 0
		for i=_labels.size() - 1 to 0
			if _labelTimes.get(i) < _delimiter
				label.delete(_labels.remove(i))
				_labelTimes.remove(i)

var ec_labelSize=ffUtil.size(ec_labelSizeInput)
var ec_lineTransparency=ffUtil.lineTrnsp(ec_lineWeightInput)
var ec_lineStyle=ffUtil.lineStyle(ec_lineStyleInput)
var ec_tableLocation=ffUtil.boxLoc(ec_tableX, ec_tableY)
var ec_impactFilter=ffUtil.impFilter(ec_holiday, ec_lowImpact, ec_medImpact, ec_highImpact)
var ec_currencyFilter=ffUtil.curFilter(ec_autoCurrency, ec_AUD, ec_CAD, ec_CHF, ec_CNY, ec_EUR, ec_GBP, ec_JPY, ec_NZD, ec_USD)
var array<ffUtil.News> ec_currentWeek=array.new<ffUtil.News>()
var array<ffUtil.News> ec_nextWeek=array.new<ffUtil.News>()
var array<ffUtil.News> ec_currentDay=array.new<ffUtil.News>()
var array<line> ec_chartLines=array.new_line()
var array<int> ec_chartLineTimes=array.new_int()
var array<label> ec_chartLabels=array.new_label()
var array<int> ec_chartLabelTimes=array.new_int()
var table ec_table=na

float ec_tfSeconds=timeframe.in_seconds()
bool ec_supportedTf=not na(ec_tfSeconds) and ec_tfSeconds >= 30 and ec_tfSeconds <= 86400
string ec_timezone=ec_customTimezone ? 'UTC' + (ec_timezoneH >= 0 ? '+' : '-') + str.tostring(math.abs(ec_timezoneH)) + (ec_timezoneM == 0 ? '' : ':' + (ec_timezoneM < 10 ? '0' : '') + str.tostring(ec_timezoneM)) : 'America/New_York'
int ec_dayKey=year(time, ec_timezone) * 10000 + month(time, ec_timezone) * 100 + dayofmonth(time, ec_timezone)
bool ec_newDay=not na(ec_dayKey[1]) and ec_dayKey != ec_dayKey[1]
if ENABLE_ECON_CAL and ec_supportedTf
	string _ecChartMode=timeframe.isdaily and ec_onChartMode == 'Today' ? 'This Week' : ec_onChartMode
	string _ecTableMode=timeframe.isdaily ? 'This Week' : ec_tableMode
	color _ecTableBorder=ec_tableBorder ? (ec_borderAuto ? chart.fg_color : ec_borderColor) : na
	int _ecTimelineH=ec_customTimezone ? ec_timezoneH : int(na)
	int _ecTimelineM=ec_customTimezone ? ec_timezoneM : int(na)
	[_ecSlot1, _ecSlot2, _ecSlot3, _ecSlot4, _ecSlot5, _ecSlot6, _ecSlot7, _ecSlot8, _ecSlot9]=ec_requestData()
	if timeframe.change('W')
		ec_nextWeek := ffUtil.bubbleSort_News(ec_nextWeek)
		if ec_customTimezone
			ec_nextWeek := ffUtil.adjustTimezone(ec_nextWeek, ec_timezoneH, ec_timezoneM)
		if ec_timeFormat == 'AM/PM'
			ec_nextWeek := ffUtil.NewsAMPM_TOD(ec_nextWeek)
		ec_currentWeek := ec_nextWeek.copy()
		ec_currentWeek := ffUtil.weekNews(ec_currentWeek, ec_currencyFilter, ec_impactFilter)
		ec_nextWeek.clear()
	if ec_newDay
		ec_currentDay := f_ecTodayNews(ec_currentWeek, ec_currentDay, ec_timezone)
	ec_nextWeek.ec_processData(_ecSlot1, _ecSlot2, _ecSlot3, _ecSlot4, _ecSlot5, _ecSlot6, _ecSlot7, _ecSlot8, _ecSlot9)
	if timeframe.isdaily and timeframe.change('W')
		ec_nextWeek.ec_processData(_ecSlot1, _ecSlot2, _ecSlot3, _ecSlot4, _ecSlot5, _ecSlot6, _ecSlot7, _ecSlot8, _ecSlot9)
	if ec_currentWeek.size() > 0 and ec_showTable
		if _ecTableMode == 'Today'
			if ec_newDay or na(ec_table)
				if not na(ec_table)
					table.delete(ec_table)
				ec_table := ffUtil.FF_Table(f_ecCloneNews(ec_currentDay), ec_tableLocation, ec_tableSize, ec_headTextColor, ec_headBgColor, ec_futureTextColor, ec_rowBgColor, _ecTableBorder)
			if not na(ec_table)
				ffUtil.timeline(ec_currentDay, ec_table, ec_pastTextColor, _ecTimelineH, _ecTimelineM, true)
		else
			if timeframe.change('W') or na(ec_table)
				if not na(ec_table)
					table.delete(ec_table)
				ec_table := ffUtil.FF_Table(f_ecCloneNews(ec_currentWeek), ec_tableLocation, ec_tableSize, ec_headTextColor, ec_headBgColor, ec_futureTextColor, ec_rowBgColor, _ecTableBorder)
			if not na(ec_table)
				ffUtil.timeline(ec_currentWeek, ec_table, ec_pastTextColor, _ecTimelineH, _ecTimelineM)
	else if not na(ec_table)
		table.delete(ec_table)
		ec_table := table(na)
	f_ecPruneDrawings(ec_chartLines, ec_chartLineTimes, ec_chartLabels, ec_chartLabelTimes, _ecChartMode, ec_onChartDays, ec_lineTime, ec_timezone)
	if ec_showLines
		if _ecChartMode != 'Today' and timeframe.change('W')
			f_ecDrawLines(ec_currentWeek, ec_chartLines, ec_chartLineTimes, ec_lineTransparency, ec_lineStyle, ec_maxChartDrawings)
		else if _ecChartMode == 'Today' and ec_newDay
			f_ecDrawLines(ec_currentDay, ec_chartLines, ec_chartLineTimes, ec_lineTransparency, ec_lineStyle, ec_maxChartDrawings)
	if ec_showLabels
		f_ecDrawLabel(ec_currentWeek, ec_chartLabels, ec_chartLabelTimes, ec_labelY, ec_labelSize, ec_labelOutline, ec_maxChartDrawings)
	f_ecPruneDrawings(ec_chartLines, ec_chartLineTimes, ec_chartLabels, ec_chartLabelTimes, _ecChartMode, ec_onChartDays, ec_lineTime, ec_timezone)

// ===== ㉖ Dashboard =====
var string dash_pos  = input.string("Top Right", "Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group="㉖ Dashboard")
var string dash_size = input.string(size.small, "Text size", options=[size.tiny, size.small, size.normal], group="㉖ Dashboard")
var color  dash_bg   = input.color(color.new(color.black, 20), "Background", group="㉖ Dashboard", inline="d1")
var color  dash_txt  = input.color(color.white, "Text", group="㉖ Dashboard", inline="d1")

// Accumulator for the nearest untapped level above / below the close (mutated by reference).
type DashAcc
	float aP = na
	string aN = ""
	float bP = na
	string bN = ""

// Update the accumulator with one candidate level (mutates _acc in place).
f_dashNear(DashAcc _acc, float _p, string _nm) =>
	if not na(_p)
		if _p > close and (na(_acc.aP) or _p < _acc.aP)
			_acc.aP := _p
			_acc.aN := _nm
		if _p < close and (na(_acc.bP) or _p > _acc.bP)
			_acc.bP := _p
			_acc.bN := _nm

// Consider every un-tapped (neither close-through mitigated nor sweep-confirmed) level of an SHLevel history array.
f_dashShArr(DashAcc _acc, array<SHLevel> _arr, string _nm) =>
	for _l in _arr
		if not _l.mitigated and (na(_l.sweep) or _l.sweep.phase != 2)
			f_dashNear(_acc, _l.price, _nm)

_dashPosCnst = switch dash_pos
	"Top Left"     => position.top_left
	"Bottom Right" => position.bottom_right
	"Bottom Left"  => position.bottom_left
	=> position.top_right
var table dashTbl = table.new(_dashPosCnst, 2, 6 + (smt_useSym1 ? 1 : 0) + (smt_useSym2 ? 1 : 0), border_width=1)

if ENABLE_DASHBOARD and barstate.islast
	string _biasTxt = biasDir == 0 ? "—" : (biasDir == -1 ? "Premium" : "Discount") + (na(biasPct) ? " (gap)" : " " + str.tostring(biasPct, "#") + "%")
	color _biasCol = biasDir == 0 ? dash_bg : color.new(biasDir == -1 ? color.red : color.green, 40)
	string _structTxt = "—"
	color _structCol = dash_bg
	if ENABLE_STRUCTURE and struct_trend != 0
		_structTxt := (struct_trend == 1 ? "Bull" : "Bear") + (na(struct_lastBreak) ? "" : " · " + struct_lastBreak)
		_structCol := struct_trend == 1 ? color.new(color.green, 40) : color.new(color.red, 40)
	DashAcc _acc = DashAcc.new()
	if ENABLE_LIQUIDITY
		f_dashShArr(_acc, lq_histDayH,   "PDH")
		f_dashShArr(_acc, lq_histDayL,   "PDL")
		f_dashShArr(_acc, lq_histWeekH,  "PWH")
		f_dashShArr(_acc, lq_histWeekL,  "PWL")
		f_dashShArr(_acc, lq_histMonthH, "PMH")
		f_dashShArr(_acc, lq_histMonthL, "PML")
	if ENABLE_SESSION_HL
		f_dashShArr(_acc, sh_histAsiaH, "Asia H")
		f_dashShArr(_acc, sh_histAsiaL, "Asia L")
		f_dashShArr(_acc, sh_histLonH, "London H")
		f_dashShArr(_acc, sh_histLonL, "London L")
		f_dashShArr(_acc, sh_histNyamH, "NY AM H")
		f_dashShArr(_acc, sh_histNyamL, "NY AM L")
		f_dashShArr(_acc, sh_histNypreH, "Pre-AM H")
		f_dashShArr(_acc, sh_histNypreL, "Pre-AM L")
		f_dashShArr(_acc, sh_histNylH, "Lunch H")
		f_dashShArr(_acc, sh_histNylL, "Lunch L")
		f_dashShArr(_acc, sh_histNypmH, "NY PM H")
		f_dashShArr(_acc, sh_histNypmL, "NY PM L")
	if ENABLE_EQHL
		if eqhPools.size() > 0
			for i = 0 to eqhPools.size() - 1
				LiqPool _p = eqhPools.get(i)
				if not _p.mitigated and (na(_p.sweep) or _p.sweep.phase != 2)
					f_dashNear(_acc, _p.price, "EQH")
		if eqlPools.size() > 0
			for i = 0 to eqlPools.size() - 1
				LiqPool _p = eqlPools.get(i)
				if not _p.mitigated and (na(_p.sweep) or _p.sweep.phase != 2)
					f_dashNear(_acc, _p.price, "EQL")
	string _upTxt = na(_acc.aP) ? "—" : "↑ " + _acc.aN + " " + str.tostring(_acc.aP, format.mintick)
	string _dnTxt = na(_acc.bP) ? "—" : "↓ " + _acc.bN + " " + str.tostring(_acc.bP, format.mintick)
	string _kzTxt = kz_name
	table.cell(dashTbl, 0, 0, "Bias",      text_color=dash_txt,     text_size=dash_size, bgcolor=dash_bg)
	table.cell(dashTbl, 1, 0, _biasTxt,    text_color=color.white,  text_size=dash_size, bgcolor=_biasCol)
	table.cell(dashTbl, 0, 1, "Structure", text_color=dash_txt,     text_size=dash_size, bgcolor=dash_bg)
	table.cell(dashTbl, 1, 1, _structTxt,  text_color=color.white,  text_size=dash_size, bgcolor=_structCol)
	table.cell(dashTbl, 0, 2, "Liq ↑",     text_color=dash_txt,     text_size=dash_size, bgcolor=dash_bg)
	table.cell(dashTbl, 1, 2, _upTxt,      text_color=dash_txt,     text_size=dash_size, bgcolor=dash_bg)
	table.cell(dashTbl, 0, 3, "Liq ↓",     text_color=dash_txt,     text_size=dash_size, bgcolor=dash_bg)
	table.cell(dashTbl, 1, 3, _dnTxt,      text_color=dash_txt,     text_size=dash_size, bgcolor=dash_bg)
	table.cell(dashTbl, 0, 4, "Killzone",  text_color=dash_txt,     text_size=dash_size, bgcolor=dash_bg)
	table.cell(dashTbl, 1, 4, _kzTxt,      text_color=dash_txt,     text_size=dash_size, bgcolor=dash_bg)
	string _suTxt = not ENABLE_SETUP ? "—" : "L " + str.tostring(setupLongScore) + "/5 · S " + str.tostring(setupShortScore) + "/5"
	table.cell(dashTbl, 0, 5, "Setup",     text_color=dash_txt,     text_size=dash_size, bgcolor=dash_bg)
	table.cell(dashTbl, 1, 5, _suTxt,      text_color=dash_txt,     text_size=dash_size, bgcolor=dash_bg)
	int _smtRow = 6
	if smt_useSym1
		string _smtV1 = "—"
		if ENABLE_SMT
			int _pc1 = smtS1H.count + smtS1L.count + smtL1H.count + smtL1L.count
			int _bc1 = brk1H.count + brk1L.count
			int _smtT1 = math.max(nz(smtS1H.lastT, 0), nz(smtS1L.lastT, 0), nz(smtL1H.lastT, 0), nz(smtL1L.lastT, 0), nz(brk1H.lastT, 0), nz(brk1L.lastT, 0))
			_smtV1 := str.format("P:{0} B:{1}", _pc1, _bc1) + (_smtT1 > 0 ? " · " + str.format_time(_smtT1, "HH:mm", "America/New_York") : "")
		table.cell(dashTbl, 0, _smtRow, "SMT " + (na(smt_tk1) ? "1" : smt_tk1), text_color=dash_txt, text_size=dash_size, bgcolor=dash_bg)
		table.cell(dashTbl, 1, _smtRow, _smtV1, text_color=dash_txt, text_size=dash_size, bgcolor=dash_bg)
		_smtRow += 1
	if smt_useSym2
		string _smtV2 = "—"
		if ENABLE_SMT
			int _pc2 = smtS2H.count + smtS2L.count + smtL2H.count + smtL2L.count
			int _bc2 = brk2H.count + brk2L.count
			int _smtT2 = math.max(nz(smtS2H.lastT, 0), nz(smtS2L.lastT, 0), nz(smtL2H.lastT, 0), nz(smtL2L.lastT, 0), nz(brk2H.lastT, 0), nz(brk2L.lastT, 0))
			_smtV2 := str.format("P:{0} B:{1}", _pc2, _bc2) + (_smtT2 > 0 ? " · " + str.format_time(_smtT2, "HH:mm", "America/New_York") : "")
		table.cell(dashTbl, 0, _smtRow, "SMT " + (na(smt_tk2) ? "2" : smt_tk2), text_color=dash_txt, text_size=dash_size, bgcolor=dash_bg)
		table.cell(dashTbl, 1, _smtRow, _smtV2, text_color=dash_txt, text_size=dash_size, bgcolor=dash_bg)
		_smtRow += 1
