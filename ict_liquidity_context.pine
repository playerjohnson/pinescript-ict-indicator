var string ec_onChartMode=input.string('This Week', 'Chart history', options=['Today', 'This Week', 'Manual'], group=EC_CHART_GROUP, inline='eco1')
var int ec_onChartDays=input.int(30, '', minval=1, maxval=365, group=EC_CHART_GROUP, inline='eco1')
